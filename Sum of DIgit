#include<iostream>
using namespace std;

int main()
{
    int n, temp, reminder, sum=0;
    cout<<"Enter N Digit"<<endl;
    cin>>n;

     temp=n;
    while (temp!=0)
    {
        reminder=temp%10;
        sum=sum+reminder;
        temp=temp/10;
        
    }
    cout<<"Sum of your Digit is " <<sum;
    return 0;
    
    

}
