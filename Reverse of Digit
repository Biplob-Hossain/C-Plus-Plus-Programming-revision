#include<iostream>

using namespace std;
int main()
{

    int temp, rem, reverse=0, n;

    cout<<"Enter N digit for Reverse"<<endl;
    cin>>n;

     temp=n;
    while (temp !=0)
    {
        rem=temp % 10;
        reverse = reverse*10+rem;
        temp=temp/10;
    }
    cout<<"After Revers your number is "<<reverse<<endl;
    return 0;

    

}
